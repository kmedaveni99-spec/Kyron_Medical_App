# Kyron Medical AI - Environment Variables
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=your-groq-key
GOOGLE_API_KEY=your-gemini-key
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-32b:free
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=appointments@kyronmedical.com
# Must be publicly reachable for Twilio voice webhooks (example: https://abcd1234.ngrok-free.app)
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite+aiosqlite:///./kyron.db

